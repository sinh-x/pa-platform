{
  "name": "pa-platform",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "corepack pnpm -r build",
    "test": "corepack pnpm -r test",
    "typecheck": "corepack pnpm -r typecheck",
    "bump:patch:ci": "node scripts/dev/ci_patch_bump.mjs",
    "bump:patch": "bash scripts/dev/version_bump.sh patch",
    "bump:minor": "bash scripts/dev/version_bump.sh minor",
    "bump:major": "bash scripts/dev/version_bump.sh major",
    "bump:refresh-hash": "bash scripts/dev/version_bump.sh --refresh-hash",
    "completions": "bash scripts/dev/generate_completions.sh",
    "completions:timing": "fish scripts/dev/check_fish_completion_timing.fish",
    "secrets:scan": "bash scripts/hooks/pre-commit-secret-scan.sh"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "better-sqlite3": "11.6.0",
    "js-yaml": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.28.0"
}
